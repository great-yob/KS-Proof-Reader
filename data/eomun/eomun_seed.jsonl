{"rule_id": "WL-ACCESSORY", "regulation": "외래어 표기법", "notice_no": "문화체육관광부 고시 제2017-14호", "chapter": "제3장 표기 세칙", "section": null, "article_no": null, "rule_text": "accessory는 '액세서리'로 적는다.", "gloss": "'악세사리'는 비표준 표기이며 규범 표기는 '액세서리'.", "examples": {"correct": ["액세서리"], "incorrect": ["악세사리"]}, "triggers": ["악세사리"], "deterministic": true, "category": "외래어", "context_dependent": false, "priority": 2, "source_url": "https://korean.go.kr/kornorms/regltn/regltnView.do?regltn_code=0003"}
{"rule_id": "WL-JUICE", "regulation": "외래어 표기법", "notice_no": "문화체육관광부 고시 제2017-14호", "chapter": "제3장 표기 세칙", "section": null, "article_no": null, "rule_text": "juice는 '주스'로 적는다.", "gloss": "'쥬스'는 비표준 표기. 외래어 표기에서 '쥬/져/쵸' 등 이중모음 표기는 쓰지 않는다.", "examples": {"correct": ["주스"], "incorrect": ["쥬스"]}, "triggers": ["쥬스"], "deterministic": true, "category": "외래어", "context_dependent": false, "priority": 2, "source_url": "https://korean.go.kr/kornorms/regltn/regltnView.do?regltn_code=0003"}
{"rule_id": "WL-CHOCOLATE", "regulation": "외래어 표기법", "notice_no": "문화체육관광부 고시 제2017-14호", "chapter": "제3장 표기 세칙", "section": null, "article_no": null, "rule_text": "chocolate는 '초콜릿'으로 적는다.", "gloss": "'초콜렛/쵸콜릿'은 비표준. 규범 표기는 '초콜릿'.", "examples": {"correct": ["초콜릿"], "incorrect": ["초콜렛"]}, "triggers": ["초콜렛"], "deterministic": true, "category": "외래어", "context_dependent": false, "priority": 2, "source_url": "https://korean.go.kr/kornorms/regltn/regltnView.do?regltn_code=0003"}
{"rule_id": "WL-SUPERMARKET", "regulation": "외래어 표기법", "notice_no": "문화체육관광부 고시 제2017-14호", "chapter": "제3장 표기 세칙", "section": null, "article_no": null, "rule_text": "supermarket는 '슈퍼마켓'으로 적는다.", "gloss": "'수퍼마켓'은 비표준. super-는 '슈퍼'로 적는다.", "examples": {"correct": ["슈퍼마켓"], "incorrect": ["수퍼마켓"]}, "triggers": ["수퍼마켓"], "deterministic": true, "category": "외래어", "context_dependent": false, "priority": 3, "source_url": "https://korean.go.kr/kornorms/regltn/regltnView.do?regltn_code=0003"}
{"rule_id": "WL-ROBOT", "regulation": "외래어 표기법", "notice_no": "문화체육관광부 고시 제2017-14호", "chapter": "제3장 표기 세칙", "section": null, "article_no": null, "rule_text": "robot은 '로봇'으로 적는다.", "gloss": "'로보트'는 비표준. 어말 -t는 받침 'ㅅ'(로봇)으로 적는다.", "examples": {"correct": ["로봇"], "incorrect": ["로보트"]}, "triggers": ["로보트"], "deterministic": true, "category": "외래어", "context_dependent": false, "priority": 3, "source_url": "https://korean.go.kr/kornorms/regltn/regltnView.do?regltn_code=0003"}
{"rule_id": "WL-PLATFORM", "regulation": "외래어 표기법", "notice_no": "문화체육관광부 고시 제2017-14호", "chapter": "제3장 표기 세칙", "section": null, "article_no": null, "rule_text": "platform은 '플랫폼'으로 적는다.", "gloss": "'플랫홈'은 비표준. -form은 '폼'으로 적는다.", "examples": {"correct": ["플랫폼"], "incorrect": ["플랫홈"]}, "triggers": ["플랫홈"], "deterministic": true, "category": "외래어", "context_dependent": false, "priority": 3, "source_url": "https://korean.go.kr/kornorms/regltn/regltnView.do?regltn_code=0003"}
{"rule_id": "WL-CAFE", "regulation": "외래어 표기법", "notice_no": "문화체육관광부 고시 제2017-14호", "chapter": "제1장 표기의 기본 원칙", "section": null, "article_no": 4, "rule_text": "파열음 표기에는 된소리를 쓰지 않는 것을 원칙으로 한다. café는 '카페'로 적는다.", "gloss": "외래어 표기에 된소리(ㄲ·ㅃ·ㅉ)를 쓰지 않는다. '까페→카페', '빠리→파리', '꼴라주→콜라주'.", "examples": {"correct": ["카페"], "incorrect": ["까페"]}, "triggers": ["까페"], "deterministic": true, "category": "외래어", "context_dependent": false, "priority": 2, "source_url": "https://korean.go.kr/kornorms/regltn/regltnView.do?regltn_code=0003"}
{"rule_id": "WL-DIGITAL", "regulation": "외래어 표기법", "notice_no": "문화체육관광부 고시 제2017-14호", "chapter": "제3장 표기 세칙", "section": null, "article_no": null, "rule_text": "digital은 '디지털'로 적는다.", "gloss": "'디지탈'은 비표준. 규범 표기는 '디지털'.", "examples": {"correct": ["디지털"], "incorrect": ["디지탈"]}, "triggers": ["디지탈"], "deterministic": true, "category": "외래어", "context_dependent": false, "priority": 3, "source_url": "https://korean.go.kr/kornorms/regltn/regltnView.do?regltn_code=0003"}
{"rule_id": "WL-TELEVISION", "regulation": "외래어 표기법", "notice_no": "문화체육관광부 고시 제2017-14호", "chapter": "제3장 표기 세칙", "section": null, "article_no": null, "rule_text": "television은 '텔레비전'으로 적는다.", "gloss": "'텔레비젼'은 비표준. '젼/쟈' 등 이중모음 표기는 쓰지 않는다.", "examples": {"correct": ["텔레비전"], "incorrect": ["텔레비젼"]}, "triggers": ["텔레비젼"], "deterministic": true, "category": "외래어", "context_dependent": false, "priority": 3, "source_url": "https://korean.go.kr/kornorms/regltn/regltnView.do?regltn_code=0003"}
{"rule_id": "SW-SEOLGEOJI", "regulation": "표준어 규정", "notice_no": "문화체육관광부 고시 제2017-13호", "chapter": "제1부 표준어 사정 원칙", "section": null, "article_no": null, "rule_text": "'설거지'를 표준어로 삼는다.", "gloss": "'설겆이'는 비표준. 어원 의식이 약해진 표기로 '설거지'를 표준으로 삼는다.", "examples": {"correct": ["설거지"], "incorrect": ["설겆이"]}, "triggers": ["설겆이"], "deterministic": true, "category": "표준어", "context_dependent": false, "priority": 2, "source_url": "https://korean.go.kr/kornorms/regltn/regltnView.do?regltn_code=0002"}
{"rule_id": "SW-GANGNANGKONG", "regulation": "표준어 규정", "notice_no": "문화체육관광부 고시 제2017-13호", "chapter": "제1부 표준어 사정 원칙", "section": "제2장 발음 변화에 따른 표준어 규정", "article_no": null, "rule_text": "'강낭콩'을 표준어로 삼는다.", "gloss": "어원에서 멀어진 형태(강남→강낭)가 굳어져 '강낭콩'이 표준어. '강남콩'은 비표준.", "examples": {"correct": ["강낭콩"], "incorrect": ["강남콩"]}, "triggers": ["강남콩"], "deterministic": true, "category": "표준어", "context_dependent": false, "priority": 3, "source_url": "https://korean.go.kr/kornorms/regltn/regltnView.do?regltn_code=0002"}
{"rule_id": "HM-0051-ILJJIGI", "regulation": "한글 맞춤법", "notice_no": "문화체육관광부 고시 제2017-12호", "chapter": "제6장 그 밖의 것", "section": null, "article_no": 51, "rule_text": "부사의 끝음절이 분명히 '이'로만 나는 것은 '-이'로 적는다. '일찍이'로 적는다.", "gloss": "'일찌기'는 비표준. 규범 표기는 '일찍이'.", "examples": {"correct": ["일찍이"], "incorrect": ["일찌기"]}, "triggers": ["일찌기"], "deterministic": true, "category": "맞춤법", "context_dependent": false, "priority": 3, "source_url": "https://korean.go.kr/kornorms/regltn/regltnView.do?regltn_code=0001"}
{"rule_id": "HM-0051-IHI", "regulation": "한글 맞춤법", "notice_no": "문화체육관광부 고시 제2017-12호", "chapter": "제6장 그 밖의 것", "section": null, "article_no": 51, "rule_text": "부사의 끝음절이 '이'로만 나는 것은 '-이'로, '히'로 나거나 '이/히'로 나는 것은 '-히'로 적는다.", "gloss": "'-이'와 '-히' 구별. '깨끗이·가까이·일일이'(이), '꼼꼼히·정확히·솔직히'(히). 첩어·ㅅ받침 뒤는 대개 '-이'. 맥락에 따라 다르므로 일괄 치환 금지.", "examples": {"correct": ["깨끗이", "꼼꼼히", "정확히"], "incorrect": ["깨끗히", "꼼꼼이"]}, "triggers": ["깨끗히"], "deterministic": false, "category": "맞춤법", "context_dependent": true, "priority": 2, "source_url": "https://korean.go.kr/kornorms/regltn/regltnView.do?regltn_code=0001"}
{"rule_id": "HM-0010-DUEUM-N", "regulation": "한글 맞춤법", "notice_no": "문화체육관광부 고시 제2017-12호", "chapter": "제3장 소리에 관한 것", "section": "제5절 두음 법칙", "article_no": 10, "rule_text": "한자음 '녀, 뇨, 뉴, 니'가 단어 첫머리에 올 적에는 두음 법칙에 따라 '여, 요, 유, 이'로 적는다.", "gloss": "단어 첫머리에서만 적용. 단어 중간이면 본음대로(남녀·당뇨). 의존명사(냥·년)는 예외. 위치 의존이므로 자동 치환 금지 — 문맥 판단 필요.", "examples": {"correct": ["여자", "연도", "이토"], "incorrect": ["녀자", "년도(단어 첫머리)"]}, "triggers": ["녀자"], "deterministic": false, "category": "맞춤법", "context_dependent": true, "priority": 2, "source_url": "https://korean.go.kr/kornorms/regltn/regltnView.do?regltn_code=0001"}
{"rule_id": "HM-0011-DUEUM-R", "regulation": "한글 맞춤법", "notice_no": "문화체육관광부 고시 제2017-12호", "chapter": "제3장 소리에 관한 것", "section": "제5절 두음 법칙", "article_no": 11, "rule_text": "한자음 '랴, 려, 례, 료, 류, 리'가 단어 첫머리에 올 적에는 '야, 여, 예, 요, 유, 이'로 적는다.", "gloss": "단어 첫머리에서만. '력사→역사', '리유→이유'. 단어 중간은 본음(협력·도리). 위치 의존 — 자동 치환 금지.", "examples": {"correct": ["역사", "이유", "예의"], "incorrect": ["력사", "리유"]}, "triggers": ["력사", "리유"], "deterministic": false, "category": "맞춤법", "context_dependent": true, "priority": 2, "source_url": "https://korean.go.kr/kornorms/regltn/regltnView.do?regltn_code=0001"}
{"rule_id": "HM-0012-DUEUM-R2", "regulation": "한글 맞춤법", "notice_no": "문화체육관광부 고시 제2017-12호", "chapter": "제3장 소리에 관한 것", "section": "제5절 두음 법칙", "article_no": 12, "rule_text": "한자음 '라, 래, 로, 뢰, 루, 르'가 단어 첫머리에 올 적에는 '나, 내, 노, 뇌, 누, 느'로 적는다.", "gloss": "단어 첫머리에서만. '락원→낙원', '로인→노인'. 단어 중간은 본음(쾌락·거래). 위치 의존 — 자동 치환 금지.", "examples": {"correct": ["낙원", "노인", "내일"], "incorrect": ["락원", "로인"]}, "triggers": ["락원", "로인"], "deterministic": false, "category": "맞춤법", "context_dependent": true, "priority": 3, "source_url": "https://korean.go.kr/kornorms/regltn/regltnView.do?regltn_code=0001"}
{"rule_id": "HM-0006-GUGAE", "regulation": "한글 맞춤법", "notice_no": "문화체육관광부 고시 제2017-12호", "chapter": "제3장 소리에 관한 것", "section": "제2절 구개음화", "article_no": 6, "rule_text": "'ㄷ, ㅌ' 받침 뒤에 종속적 관계의 '-이(-)', '-히-'가 올 적에는, 소리가 [ㅈ, ㅊ]으로 나더라도 'ㄷ, ㅌ'으로 적는다.", "gloss": "발음은 구개음화돼도 표기는 본디 받침을 유지. '맏이[마지]→맏이', '해돋이[해도지]→해돋이', '굳이[구지]→굳이'. 소리대로 적으면 오류.", "examples": {"correct": ["맏이", "해돋이", "굳이", "같이"], "incorrect": ["마지", "해도지", "구지", "가치"]}, "triggers": ["해도지", "구지"], "deterministic": false, "category": "맞춤법", "context_dependent": true, "priority": 3, "source_url": "https://korean.go.kr/kornorms/regltn/regltnView.do?regltn_code=0001"}
{"rule_id": "HM-0030-SAISIOT", "regulation": "한글 맞춤법", "notice_no": "문화체육관광부 고시 제2017-12호", "chapter": "제4장 형태에 관한 것", "section": "제4절 합성어 및 접두사가 붙은 말", "article_no": 30, "rule_text": "사이시옷은 정해진 조건(합성어, 앞말 모음 끝, 뒷말 된소리/ㄴ덧남 등)에서 받쳐 적는다.", "gloss": "조건이 까다로워 일괄 적용 금지. '등교길→등굣길', '최대값→최댓값', '나무잎→나뭇잎', '해살→햇살'. 한자어 사이는 6개(곳간·셋방·숫자·찻간·툇간·횟수)만 예외적으로 적음. 문맥·구성 판단 필요.", "examples": {"correct": ["등굣길", "최댓값", "나뭇잎", "햇살"], "incorrect": ["등교길", "최대값"]}, "triggers": ["등교길", "최대값"], "deterministic": false, "category": "맞춤법", "context_dependent": true, "priority": 2, "source_url": "https://korean.go.kr/kornorms/regltn/regltnView.do?regltn_code=0001"}
{"rule_id": "HM-DOE-DWAE", "regulation": "한글 맞춤법", "notice_no": "문화체육관광부 고시 제2017-12호", "chapter": "제4장 형태에 관한 것", "section": null, "article_no": null, "rule_text": "'되-'와 '되어'의 준말 '돼'를 구별해 적는다.", "gloss": "'돼=되어'. '되어'로 풀어 말이 되면 '돼', 안 되면 '되'. '안 돼(되어)', '됐다(되었다)', '되고·되니'. 문장 위치에 따라 다르므로 자동 치환 절대 금지 — AI 문맥 판단 전담.", "examples": {"correct": ["안 돼", "됐다", "되고"], "incorrect": ["안 되(서술 종결)", "됬다"]}, "triggers": ["됬다"], "deterministic": false, "category": "맞춤법", "context_dependent": true, "priority": 1, "source_url": "https://korean.go.kr/kornorms/regltn/regltnView.do?regltn_code=0001"}
{"rule_id": "HM-AN-ANH", "regulation": "한글 맞춤법", "notice_no": "문화체육관광부 고시 제2017-12호", "chapter": "제5장 띄어쓰기", "section": null, "article_no": null, "rule_text": "부정 부사 '안'과 어간 '않-'을 구별한다.", "gloss": "'안'=부사 '아니'의 준말(뒤 띄움). '않-'=보조용언 '아니하-'의 준말(붙임). '안 가다'(부사)·'가지 않다'(보조용언). 위치·구성 의존 — 자동 치환 금지.", "examples": {"correct": ["안 가다", "가지 않다", "하지 않았다"], "incorrect": ["안가다(부정)", "않 가다"]}, "triggers": [], "deterministic": false, "category": "맞춤법", "context_dependent": true, "priority": 1, "source_url": "https://korean.go.kr/kornorms/regltn/regltnView.do?regltn_code=0001"}
{"rule_id": "HM-0042-UIJON", "regulation": "한글 맞춤법", "notice_no": "문화체육관광부 고시 제2017-12호", "chapter": "제5장 띄어쓰기", "section": "제2절 의존 명사, 단위를 나타내는 명사 및 열거하는 말 등", "article_no": 42, "rule_text": "의존 명사는 띄어 쓴다.", "gloss": "'수·것·줄·만큼·때·바·뿐' 등 의존명사는 앞말과 띄어 쓴다. '갈 수 있다', '할 줄 안다', '아는 것이 힘이다', '먹을 만하다'. 조사로 쓰일 땐 붙임(너뿐이다)에 주의.", "examples": {"correct": ["갈 수 있다", "할 때", "먹을 만하다"], "incorrect": ["갈수있다", "할때", "먹을만하다"]}, "triggers": ["갈수있다", "할때", "먹을만하다"], "deterministic": false, "category": "띄어쓰기", "context_dependent": true, "priority": 1, "source_url": "https://korean.go.kr/kornorms/regltn/regltnView.do?regltn_code=0001"}
{"rule_id": "HM-0043-DANWI", "regulation": "한글 맞춤법", "notice_no": "문화체육관광부 고시 제2017-12호", "chapter": "제5장 띄어쓰기", "section": "제2절 의존 명사, 단위를 나타내는 명사 및 열거하는 말 등", "article_no": 43, "rule_text": "단위를 나타내는 명사는 띄어 쓴다.", "gloss": "'개·명·시간·마리·원' 등 단위명사는 띄어 쓴다. '한 개', '두 명', '세 시간'. 다만 순서·아라비아 숫자 뒤는 붙여 쓸 수 있다(2개·제3장).", "examples": {"correct": ["한 개", "두 명", "세 시간"], "incorrect": ["한개", "두명"]}, "triggers": ["한개", "두명"], "deterministic": false, "category": "띄어쓰기", "context_dependent": true, "priority": 2, "source_url": "https://korean.go.kr/kornorms/regltn/regltnView.do?regltn_code=0001"}
{"rule_id": "RM-VOWEL-UI", "regulation": "국어의 로마자 표기법", "notice_no": "문화체육관광부 고시 제2014-42호", "chapter": "제2장 표기 일람", "section": null, "article_no": 1, "rule_text": "'ㅢ'는 'ㅣ'로 소리 나더라도 'ui'로 적는다.", "gloss": "로마자 표기는 표준 발음법에 따르되 'ㅢ'는 항상 'ui'. 예: 광희문 Gwanghuimun. 장모음은 표기에 반영하지 않는다.", "examples": {"correct": ["Gwanghuimun"], "incorrect": ["Gwanghimun"]}, "triggers": [], "deterministic": false, "category": "로마자", "context_dependent": true, "priority": 3, "source_url": "https://korean.go.kr/kornorms/regltn/regltnView.do?regltn_code=0004"}
{"rule_id": "RM-CONSONANT-POS", "regulation": "국어의 로마자 표기법", "notice_no": "문화체육관광부 고시 제2014-42호", "chapter": "제2장 표기 일람", "section": null, "article_no": 2, "rule_text": "'ㄱ, ㄷ, ㅂ'은 모음 앞에서는 'g, d, b'로, 자음 앞이나 어말에서는 'k, t, p'로 적는다.", "gloss": "위치에 따라 표기가 달라진다. 구미 Gumi, 옥천 Okcheon, 한밭[한받] Hanbat. 'ㄹ'은 모음 앞 r, 자음 앞·어말 l, 'ㄹㄹ'은 ll.", "examples": {"correct": ["Gumi", "Okcheon", "Hanbat"], "incorrect": ["Gumi(어말 g)", "Okcheon"]}, "triggers": [], "deterministic": false, "category": "로마자", "context_dependent": true, "priority": 3, "source_url": "https://korean.go.kr/kornorms/regltn/regltnView.do?regltn_code=0004"}
